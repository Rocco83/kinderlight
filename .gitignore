# KinderLight RGB - .gitignore

# Editor
*.bak
*.tmp
*.swp
*.swo
*.swn

# OS
.DS_Store
Thumbs.db
ehthumbs.db

# KiCad
*.backup
*.kicad_prl
*.kicad_wks
*.kicad_sch-bak
*-cache.lib
*-rescue.kicad_sch
*-rescue.*
*-bak.kicad_pcb
*-bak.kicad_sch

# KiCad project auto-save
*.kicad_pro-bak
\#auto_saved_files\#

# KiCad auto-save and backup files
*.kicad_pcb-bak
*.kicad_sch-bak
*.bak
*.bck
*-bak/
*_bak/
*-backups/

# Output
/gerbers_front/
/gerbers_rear/
/build/
/dist/

# Other temporary files
*.tar.gz
*.7z

# KiCad lock files (created when project is open)
*.lck

# KiCad cache
fp-info-cache

# standard files to not version
*.log
*.aux
*.out
*.toc

# files with passwords
# secrets is also in the firmware directory
secrets.yaml
